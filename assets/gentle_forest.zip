uot;user_id&quot;:13663259}" class="community_post has_vote_column has_replies"><div id="first-post" class="post_anchor"></div><div class="post_grid"><div class="post_votes"><a class="vote_up_btn vote_btn" href="https://itch.io/login?return_to=https%3A%2F%2Fseliel-the-shaper.itch.io%2Fgentle-forest&amp;intent=community" title="Vote up" data-register_action="community_vote"><svg version="1.1" width="20" class="svgicon icon_vote_up" aria-hidden viewBox="0 0 24 24" role="img" height="20"><polygon points="2 18 12 6 22 18" /></svg></a> <a class="vote_down_btn vote_btn" href="https://itch.io/login?return_to=https%3A%2F%2Fseliel-the-shaper.itch.io%2Fgentle-forest&amp;intent=community" title="Vote down" data-register_action="community_vote"><svg version="1.1" width="20" class="svgicon icon_vote_down" aria-hidden viewBox="0 0 24 24" role="img" height="20"><polygon points="2 6 12 18 22 6" /></svg></a></div><a href="https://itch.io/profile/nekozer" class="avatar_container"><div style="background-image: url(/static/images/frog-blue.png)" class="post_avatar"></div></a><div class="post_header"><span class="post_author"><a href="https://itch.io/profile/nekozer">nekozer</a></span><span title="2025-06-19 03:12:27" class="post_date"><a href="https://itch.io/post/13165995">14 days ago</a></span><span class="vote_counts"></span></div><div class="post_content"><div dir="auto" class="post_body user_formatted"><p>Can I use this pack for my college gaming project?</p></div><div class="post_footer"><a href="https://itch.io/login?return_to=https%3A%2F%2Fseliel-the-shaper.itch.io%2Fgentle-forest&amp;intent=community" class="post_action reply_btn" data-register_action="community_reply">Reply</a></div></div></div></div><div class="community_post_replies top_level_replies"><div id="post-13166879" data-post="{&quot;id&quot;:13166879,&quot;user_id&quot;:1278838}" class="community_post has_vote_column is_reply"><div class="post_grid"><div class="post_votes"><a class="vote_up_btn vote_btn" href="https://itch.io/login?return_to=https%3A%2F%2Fseliel-the-shaper.itch.io%2Fgentle-forest&amp;intent=community" title="Vote up" data-register_action="community_vote"><svg version="1.1" width="20" class="svgicon icon_vote_up" aria-hidden viewBox="0 0 24 24" role="img" height="20"><polygon points="2 18 12 6 22 18" /></svg></a> <a class="vote_down_btn vote_btn" href="https://itch.io/login?return_to=https%3A%2F%2Fseliel-the-shaper.itch.io%2Fgentle-forest&amp;intent=community" title="Vote down" data-register_action="community_vote"><svg version="1.1" width="20" class="svgicon icon_vote_down" aria-hidden viewBox="0 0 24 24" role="img" height="20"><polygon points="2 6 12 18 22 6" /></svg></a></div><a href="https://itch.io/profile/seliel-the-shaper" class="avatar_container"><div style="background-image: url(https://img.itch.zone/aW1nLzIwMjE2NzM2LnBuZw==/25x25%23/%2BOhmGY.png)" class="post_avatar"></div></a><div class="post_header"><span class="post_author"><a href="https://itch.io/profile/seliel-the-shaper">Seliel the Shaper</a></span><span title="2025-06-19 06:56:39" class="post_date"><a href="https://itch.io/post/13166879">14 days ago</a></span><span class="vote_counts"></span></div><div class="post_content"><div dir="auto" class="post_body user_formatted"><p>You sure can! But here&#x27;s a <a href="https://selieltheshaper.weebly.com/user-license.html" target="_blank" referrerpolicy="origin" rel="nofollow noopener">link</a> to the full licence.</p></div><div class="post_footer"><a href="https://itch.io/login?return_to=https%3A%2F%2Fseliel-the-shaper.itch.io%2Fgentle-forest&amp;intent=community" class="post_action reply_btn" data-register_action="community_reply">Reply</a></div></div></div></div></div><div id="post-12687823" data-post="{&quot;id&quot;:12687823,&quot;user_id&quot;:12986546}" class="community_post has_vote_column has_replies"><div class="post_grid"><div class="post_votes"><a class="vote_up_btn vote_btn" href="https://itch.io/login?return_to=https%3A%2F%2Fseliel-the-shaper.itch.io%2Fgentle-forest&amp;intent=community" title="Vote up" data-register_action="community_vote"><svg version="1.1" width="20" class="svgicon icon_vote_up" aria-hidden viewBox="0 0 24 24" role="img" height="20"><polygon points="2 18 12 6 22 18" /></svg></a> <a class="vote_down_btn vote_btn" href="https://itch.io/login?return_to=https%3A%2F%2Fseliel-the-shaper.itch.io%2Fgentle-forest&amp;intent=community" title="Vote down" data-register_action="community_vote"><svg version="1.1" width="20" class="svgicon icon_vote_down" aria-hidden viewBox="0 0 24 24" role="img" height="20"><polygon points="2 6 12 18 22 6" /></svg></a></div><a href="https://itch.io/profile/cleberrmor" class="avatar_container"><div style="background-image: url(/static/images/frog-cyan.png)" class="post_avatar"></div></a><div class="post_header"><span class="post_author"><a href="https://itch.io/profile/cleberrmor">CleberRMor</a></span><span title="2025-04-22 14:08:37" class="post_date"><a href="https://itch.io/post/12687823">71 days ago</a></span><span class="vote_counts"></span></div><div class="post_content"><div dir="auto" class="post_body user_formatted"><p>I purchased the Pack. Can I use your art in my game and also other people&#x27;s art in the same game? For example: the character and environment are yours, can I use another artist&#x27;s enemies and interface?</p></div><div class="post_footer"><a href="https://itch.io/login?return_to=https%3A%2F%2Fseliel-the-shaper.itch.io%2Fgentle-forest&amp;intent=community" class="post_action reply_btn" data-register_action="community_reply">Reply</a></div></div></div></div><div class="community_post_replies top_level_replies"><div id="post-12687900" data-post="{&quot;id&quot;:12687900,&quot;user_id&quot;:1278838}" class="community_post has_vote_column is_reply"><div class="post_grid"><div class="post_votes"><a class="vote_up_btn vote_btn" href="https://itch.io/login?return_to=https%3A%2F%2Fseliel-the-shaper.itch.io%2Fgentle-forest&amp;intent=community" title="Vote up" data-register_action="community_vote"><svg version="1.1" width="20" class="svgicon icon_vote_up" aria-hidden viewBox="0 0 24 24" role="img" height="20"><polygon points="2 18 12 6 22 18" /></svg></a> <a class="vote_down_btn vote_btn" href="https://itch.io/login?return_to=https%3A%2F%2Fseliel-the-shaper.itch.io%2Fgentle-forest&amp;intent=community" title="Vote down" data-register_action="community_vote"><svg version="1.1" width="20" class="svgicon icon_vote_down" aria-hidden viewBox="0 0 24 24" role="img" height="20"><polygon points="2 6 12 18 22 6" /></svg></a></div><a href="https://itch.io/profile/seliel-the-shaper" class="avatar_container"><div style="background-image: url(https://img.itch.zone/aW1nLzIwMjE2NzM2LnBuZw==/25x25%23/%2BOhmGY.png)" class="post_avatar"></div></a><div class="post_header"><span class="post_author"><a href="https://itch.io/profile/seliel-the-shaper">Seliel the Shaper</a></span><span title="2025-04-22 14:21:22" class="post_date"><a href="https://itch.io/post/12687900">71 days ago</a></span><span class="vote_counts"></span></div><div class="post_content"><div dir="auto" class="post_body user_formatted"><p>Yes, if you like the way it looks, then you&#x27;re welcome to mix and match assets from different creators. Good luck on your project 😁👍</p></div><div class="post_footer"><a href="https://itch.io/login?return_to=https%3A%2F%2Fseliel-the-shaper.itch.io%2Fgentle-forest&amp;intent=community" class="post_action reply_btn" data-register_action="community_reply">Reply</a></div></div></div></div></div><div id="post-11060428" data-post="{&quot;id&quot;:11060428,&quot;user_id&quot;:11709386}" class="community_post has_vote_column has_replies"><div class="post_grid"><div class="post_votes"><a class="vote_up_btn vote_btn" href="https://itch.io/login?return_to=https%3A%2F%2Fseliel-the-shaper.itch.io%2Fgentle-forest&amp;intent=community" title="Vote up" data-register_action="community_vote"><svg version="1.1" width="20" class="svgicon icon_vote_up" aria-hidden viewBox="0 0 24 24" role="img" height="20"><polygon points="2 18 12 6 22 18" /></svg></a> <a class="vote_down_btn vote_btn" href="https://itch.io/login?return_to=https%3A%2F%2Fseliel-the-shaper.itch.io%2Fgentle-forest&amp;intent=community" title="Vote down" data-register_action="community_vote"><svg version="1.1" width="20" class="svgicon icon_vote_down" aria-hidden viewBox="0 0 24 24" role="img" height="20"><polygon points="2 6 12 18 22 6" /></svg></a></div><a href="https://itch.io/profile/ibogdee" class="avatar_container"><div style="background-image: url(/static/images/frog-cyan.png)" class="post_avatar"></div></a><div class="post_header"><span class="post_author"><a href="https://itch.io/profile/ibogdee">IBogDee</a></span><span title="2024-10-03 23:36:34" class="post_date"><a href="https://itch.io/post/11060428">272 days ago</a></span> <span class="edit_message">(1 edit)</span> <span class="vote_counts"></span></div><div class="post_content"><div dir="auto" class="post_body user_formatted"><p><img src="https://img.itch.zone/aW1nLzE4MDMyNDIzLnBuZw==/original/JsSj6e.png" loading="lazy">hey , i have a Question if you know on what size to set the tilemap and what size to set the hero, because I think it happened that the hero is to small .&nbsp;thanks allot for the help&nbsp;</p></div><div class="post_footer"><a href="https://itch.io/login?return_to=https%3A%2F%2Fseliel-the-shaper.itch.io%2Fgentle-forest&amp;intent=community" class="post_action reply_btn" data-register_action="community_reply">Reply</a></div></div></div></div><div class="community_post_replies top_level_replies"><div id="post-11061057" data-post="{&quot;id&quot;:11061057,&quot;user_id&quot;:1278838}" class="community_post has_vote_column is_reply has_replies"><div class="post_grid"><div class="post_votes"><a class="vote_up_btn vote_btn" href="https://itch.io/login?return_to=https%3A%2F%2Fseliel-the-shaper.itch.io%2Fgentle-forest&amp;intent=community" title="Vote up" data-register_action="community_vote"><svg version="1.1" width="20" class="svgicon icon_vote_up" aria-hidden viewBox="0 0 24 24" role="img" height="20"><polygon points="2 18 12 6 22 18" /></svg></a> <a class="vote_down_btn vote_btn" href="https://itch.io/login?return_to=https%3A%2F%2Fseliel-the-shaper.itch.io%2Fgentle-forest&amp;intent=community" title="Vote down" data-register_action="community_vote"><svg version="1.1" width="20" class="svgicon icon_vote_down" aria-hidden viewBox="0 0 24 24" role="img" height="20"><polygon points="2 6 12 18 22 6" /></svg></a></div><a href="https://itch.io/profile/seliel-the-shaper" class="avatar_container"><div style="background-image: url(https://img.itch.zone/aW1nLzIwMjE2NzM2LnBuZw==/25x25%23/%2BOhmGY.png)" class="post_avatar"></div></a><div class="post_header"><span class="post_author"><a href="https://itch.io/profile/seliel-the-shaper">Seliel the Shaper</a></span><span title="2024-10-04 01:57:11" class="post_date"><a href="https://itch.io/post/11061057">272 days ago</a></span><span class="vote_counts"><span class="upvotes">(+1)</span></span></div><div class="post_content"><div dir="auto" class="post_body user_formatted"><p>You shouldn&#x27;t change the size of either. I&#x27;m not sure how you ended up with that. This is a question for whatever game engine you&#x27;re using, maybe some asset import setting? It should be consistent across all your assets.</p><p>You can try joining the <a href="https://selieltheshaper.weebly.com/discord.html" target="_blank" referrerpolicy="origin" rel="nofollow noopener">Mana Seed Discord server</a> and asking someone who&#x27;s familiar with your game engine if they know where you went wrong.</p></div><div class="post_footer"><a href="https://itch.io/login?return_to=https%3A%2F%2Fseliel-the-shaper.itch.io%2Fgentle-forest&amp;intent=community" class="post_action reply_btn" data-register_action="community_reply">Reply</a></div></div></div></div><div class="community_post_replies"><div id="post-11116345" data-post="{&quot;id&quot;:11116345,&quot;user_id&quot;:11779020}" class="community_post has_vote_column is_reply has_replies"><div class="post_grid"><div class="post_votes"><a class="vote_up_btn vote_btn" href="https://itch.io/login?return_to=https%3A%2F%2Fseliel-the-shaper.itch.io%2Fgentle-forest&amp;intent=community" title="Vote up" data-register_action="community_vote"><svg version="1.1" width="20" class="svgicon icon_vote_up" aria-hidden viewBox="0 0 24 24" role="img" height="20"><polygon points="2 18 12 6 22 18" /></svg></a> <a class="vote_down_btn vote_btn" href="https://itch.io/login?return_to=https%3A%2F%2Fseliel-the-shaper.itch.io%2Fgentle-forest&amp;intent=community" title="Vote down" data-register_action="community_vote"><svg version="1.1" width="20" class="svgicon icon_vote_down" aria-hidden viewBox="0 0 24 24" role="img" height="20"><polygon points="2 6 12 18 22 6" /></svg></a></div><a href="https://itch.io/profile/miraku-dev" class="avatar_container"><div style="background-image: url(/static/images/frog.png)" class="post_avatar"></div></a><div class="post_header"><span class="post_author"><a href="https://itch.io/profile/miraku-dev">Miraku-dev</a></span><span title="2024-10-12 15:20:49" class="post_date"><a href="https://itch.io/post/11116345">263 days ago</a></span><span class="vote_counts"><span class="downvotes">(-2)</span></span></div><div class="post_content"><div dir="auto" class="post_body user_formatted"><p>Hi! Is there any way I can contact you to buy this <a href="https://itch.io/s/130490/-make-a-farming-sim-bundle">https://itch.io/s/130490/-make-a-farming-sim-bundle</a>&nbsp; bundle with some kind of cryptocurrency?</p></div><div class="post_footer"><a href="https://itch.io/login?return_to=https%3A%2F%2Fseliel-the-shaper.itch.io%2Fgentle-forest&amp;intent=community" class="post_action reply_btn" data-register_action="community_reply">Reply</a></div></div></div></div><div class="community_post_replies"><div id="post-11116384" data-post="{&quot;id&quot;:11116384,&quot;user_id&quot;:1278838}" class="community_post has_vote_column is_reply has_replies"><div class="post_grid"><div class="post_votes"><a class="vote_up_btn vote_btn" href="https://itch.io/login?return_to=https%3A%2F%2Fseliel-the-shaper.itch.io%2Fgentle-forest&amp;intent=community" title="Vote up" data-register_action="community_vote"><svg version="1.1" width="20" class="svgicon icon_vote_up" aria-hidden viewBox="0 0 24 24" role="img" height="20"><polygon points="2 18 12 6 22 18" /></svg></a> <a class="vote_down_btn vote_btn" href="https://itch.io/login?return_to=https%3A%2F%2Fseliel-the-shaper.itch.io%2Fgentle-forest&amp;intent=community" title="Vote down" data-register_action="community_vote"><svg version="1.1" width="20" class="svgicon icon_vote_down" aria-hidden viewBox="0 0 24 24" role="img" height="20"><polygon points="2 6 12 18 22 6" /></svg></a></div><a href="https://itch.io/profile/seliel-the-shaper" class="avatar_container"><div style="background-image: url(https://img.itch.zone/aW1nLzIwMjE2NzM2LnBuZw==/25x25%23/%2BOhmGY.png)" class="post_avatar"></div></a><div class="post_header"><span class="post_author"><a href="https://itch.io/profile/seliel-the-shaper">Seliel the Shaper</a></span><span title="2024-10-12 15:30:19" class="post_date"><a href="https://itch.io/post/11116384">263 days ago</a></span> <span class="edit_message">(1 edit)</span> <span class="vote_counts"><span class="upvotes">(+2)</span></span></div><div class="post_content"><div dir="auto" class="post_body user_formatted"><p>Sorry, no. I am firmly anti-crypto. Please read the <a href="https://selieltheshaper.weebly.com/user-license.html" target="_blank" referrerpolicy="origin" rel="nofollow noopener">Mana Seed User License</a>&nbsp;before purchasing any of my assets. Thank you 🙏🏽</p></div><div class="post_footer"><a href="https://itch.io/login?return_to=https%3A%2F%2Fseliel-the-shaper.itch.io%2Fgentle-forest&amp;intent=community" class="post_action reply_btn" da